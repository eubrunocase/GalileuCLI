# ═════════════════════════════════════════════════════════════════════════════
# galileu.yml — Configuração do Proxy de Segurança para Ferramentas de AI
#
# Este ficheiro controla o comportamento do Galileu.
# Não é necessário tocar no código Go para alterar os padrões de detecção.
#
# MODOS DE OPERAÇÃO DO PROXY:
#   whitelist → Apenas hosts permitidos são analisados (padrão, retrocompatível)
#   passive   → Todos os hosts são analisados (exceto skip_hosts)
#
# WILDCARDS:
#   *.openai.com       → Casa com api.openai.com, chat.openai.com, etc.
#   *.telemetry.*      → Casa com qualquer subdomínio de telemetry
#
# DETECÇÃO AUTOMÁTICA:
#   O Galileu detecta automaticamente requisições de AI pelo payload:
#   - Campo 'model' presente
#   - Campo 'messages' (formato OpenAI)
#   - Campo 'contents' (formato Google Gemini)
#   - Campo 'anthropic_version' (Anthropic API)
#   - Campo 'prompt' ou 'input' (outras APIs)
# ═════════════════════════════════════════════════════════════════════════════

port: 9000

# ─── Configuração do Proxy ───────────────────────────────────────────────
# Controla quais requisições são analisadas para dados sensíveis

proxy:
  # Modo de operação: "whitelist" (padrão) ou "passive"
  mode: whitelist

  # Hosts permitidos (usado apenas no modo whitelist)
  # Suporta wildcards: *.dominio.com casa com sub.dominio.com
  allowed_hosts:
    - "*.openai.com"
    - "*.anthropic.com"
    - "*.generativelanguage.googleapis.com"
    - "*.aistudio.googleapis.com"
    - "*.cohere.ai"
    - "*.mistral.ai"
    - "*.opencode.ai"

  # Hosts sempre ignorados (telemetry, analytics, etc.)
  # Omitir para aceitar todos exceto os padrões internos
  skip_hosts:
    - "mobile.events.data.microsoft.com"
    - "telemetry.opencode.ai"
    - "*.telemetry.*"
    - "*.analytics.*"

analyzer:

  # ─── Padrões embutidos ─────────────────────────────────────────────────
  built_in:
    openai_key:         true
    openai_project_key: true
    anthropic_key:      true
    google_key:         true
    github_token:       true
    slack_token:        true
    discord_token:      true
    aws_key:            true

  # ─── Padrões personalizados ──────────────────────────────────────────────
  # Para activar, mude enabled: false para enabled: true
  custom_patterns:

    # Detectar passwords de base de dados em variáveis de ambiente
    - name: "Password de Base de Dados"
      type: regex
      pattern: 'DB_PASSWORD\s*=\s*[\x27]?[^\s\x27]+'
      label: "[DB_PASSWORD_REDACTED]"
      enabled: true

    # Detectar connection strings completas (Postgres, MySQL, MongoDB)
    - name: "Connection String de Base de Dados"
      type: regex
      pattern: '(postgres|postgresql|mysql|mongodb|redis)://[^\s]+'
      label: "[CONNECTION_STRING_REDACTED]"
      enabled: true

    # Detectar nomes de tabelas internas da empresa
    - name: "Tabelas Internas"
      type: literal
      values:
        - "clientes_vip"
        - "transacoes_internas"
        - "dados_financeiros_2024"
        - "relatorio_executivo"
      label: "[INTERNAL_TABLE_REDACTED]"
      enabled: true

    # Detectar nomes de projectos ou operações confidenciais
    - name: "Projectos Confidenciais"
      type: literal
      values:
        - "Operação Phoenix"
        - "Projecto Stargate"
        - "Iniciativa Alpha"
        - "Missão Especial 2024"
      label: "[CONFIDENTIAL_PROJECT_REDACTED]"
      enabled: true

    # Detectar tokens JWT
    - name: "JWT Token"
      type: regex
      pattern: 'eyJ[a-zA-Z0-9_-]+\.eyJ[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+'
      label: "[JWT_REDACTED]"
      enabled: true

    # Detectar chaves privadas SSH/RSA
    - name: "Chave Privada"
      type: regex
      pattern: '-----BEGIN.*PRIVATE KEY-----'
      label: "[PRIVATE_KEY_REDACTED]"
      enabled: true

# ═════════════════════════════════════════════════════════════════════════════
# EXEMPLOS DE CONFIGURAÇÃO
# ═════════════════════════════════════════════════════════════════════════════
#
# MODO PASSIVO (para usar com Claude Code, Cursor, Windsurf, etc.):
#
# proxy:
#   mode: passive
#   skip_hosts:
#     - "*.telemetry.*"
#     - "*.analytics.*"
#
# MODO WHITELIST COM HOSTS CUSTOMIZADOS:
#
# proxy:
#   mode: whitelist
#   allowed_hosts:
#     - "api.openai.com"
#     - "api.anthropic.com"
#     - "api.custom-llm.com"
#   skip_hosts:
#     - "internal.metrics.company.com"
#
# SEM CONFIGURAÇÃO (usa valores padrão, retrocompatível):
#
# proxy:
#   # Omitir seção proxy para usar configuração padrão
#   # Equivalente a mode: whitelist com os hosts padrão listados acima